# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Virtual environments
.venv/
venv/
env/
.env/
ENV/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.coveragerc
.tox/
.nox/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pyright/
.dmypy.json
dmypy.json

# ── Linters / formatters ──────────────────────────────────────────────────────
.ruff_cache/

# ── Build tools ───────────────────────────────────────────────────────────────
.hatch/

# ── OdooDevMCP runtime output ─────────────────────────────────────────────────
# Knowledge graph databases — generated by `odoo-dev-mcp index`
.odoo-dev-mcp/index.db
.odoo-dev-mcp/index.db.new
.odoo-dev-mcp/index.db-shm
.odoo-dev-mcp/index.db-wal

# INDEX_INFO.json is generated at index time — don't commit it
.odoo-dev-mcp/INDEX_INFO.json

# Keep the directory itself trackable (e.g. for .odoo-dev-mcp.toml)
!.odoo-dev-mcp/.gitkeep

# Agent Skill files — generated by `odoo-dev-mcp install`
# Commit these if you want the skill shared with your whole team;
# gitignore them if each developer runs `install` themselves.
# (Uncomment the lines below to ignore them)
# .claude/skills/odoo-dev-mcp/
# .agents/skills/odoo-dev-mcp/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Secrets & local config ────────────────────────────────────────────────────
.env
.env.local
*.pem
*.key
secrets.toml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
